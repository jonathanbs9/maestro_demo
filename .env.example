# ============================================================
# Email Reporting (.scripts/send-report-email.js)
# Used by: npm run report:email / npm run send:report:emails
# ============================================================

# Gmail account used to send the test report
EMAIL_USER=your.email@gmail.com

# Gmail App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-gmail-app-password

# Recipients of the test report email
MANAGER_EMAIL=manager@yourcompany.com
LEAD_EMAIL=lead@yourcompany.com

# ============================================================
# Maestro Cloud (optional)
# Used by: .github/workflows/android-tests-maestro-cloud.yaml
# ============================================================

# API key from https://app.maestro.dev
MAESTRO_API_KEY=your-maestro-api-key

# Project ID from your Maestro Cloud project
MAESTRO_PROJECT_ID=your-maestro-project-id

# ============================================================
# Device Cloud Dev (optional)
# Used by: .github/workflows/android-tests-dcd-cloud.yaml
# ============================================================

# API key from https://devicecloud.dev
DCD_API_KEY=your-dcd-api-key

# ============================================================
# Slack Notifications (optional)
# Used by: .github/workflows/*.yaml
# ============================================================

# Slack Incoming Webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Slack Bot OAuth Token (starts with xoxb-)
# Required only for android-tests-dcd-cloud workflow
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack Channel ID (e.g. C01234ABCDE)
# Required only for android-tests-dcd-cloud workflow
SLACK_CHANNEL_ID=your-slack-channel-id
